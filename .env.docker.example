APP_NAME=Velzon
APP_ENV=production
APP_KEY=                        # Run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres                # Docker service name — do NOT change
DB_PORT=5432
DB_DATABASE=velzon
DB_USERNAME=velzon
DB_PASSWORD=secret              # ⚠ Change this in production

# ─── Caching / Queue / Session ───────────────────────────────────────────────
# Default: all use the database (Postgres). No extra services needed.
# To use Redis instead, change all three to 'redis' AND start Docker with:
#   docker compose --profile redis up
BROADCAST_DRIVER=log
CACHE_DRIVER=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database

# ─── Redis (optional) ────────────────────────────────────────────────────────
# Only used when CACHE_DRIVER / QUEUE_CONNECTION / SESSION_DRIVER = redis
REDIS_HOST=redis                # Docker service name — do NOT change
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail (Mailpit for local dev) ────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_SECRET=                     # Run: php artisan jwt:secret

# ─── Sanctum ─────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8080

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]
